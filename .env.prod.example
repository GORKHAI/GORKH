# Core runtime
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
DEPLOYMENT_MODE=single_instance

# Database + cache
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ai_operator
# Database URL with optional connection pooling params for production
# Format: postgresql://user:password@host:port/database?connection_limit=N&pool_timeout=T
# 
# Connection pool guidance:
# - Default: Prisma uses (num_cpus * 2 + 1) connections
# - For single-instance: connection_limit=20 is a safe starting point
# - For multi-instance: divide DB max_connections by instance count
# - Always leave headroom for migrations, admin connections, etc.
# 
# Example with explicit pool settings:
# DATABASE_URL=postgresql://postgres:change_me@postgres:5432/ai_operator?connection_limit=20&pool_timeout=30
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/ai_operator
REDIS_URL=redis://redis:6379
RATE_LIMIT_BACKEND=redis

# Auth + origins
WEB_ORIGIN=https://app.example.com
APP_BASE_URL=https://app.example.com
API_PUBLIC_BASE_URL=https://api.example.com
ALLOW_INSECURE_DEV=false
# JWT configuration
# JWT_SECRET must be at least 32 characters in production (configurable via JWT_SECRET_MIN_LENGTH)
# Use a cryptographically secure random string: openssl rand -base64 48
JWT_SECRET=replace_with_long_random_secret_minimum_32_chars
# JWT_KEY_ID identifies the signing key for rotation support (default: v1)
# During rotation, deploy new keys with v2, v3, etc. and update verification logic
# JWT_KEY_ID=v1
ADMIN_API_KEY=replace_with_admin_key_minimum_16_chars

# Metrics safety: keep false on public internet
METRICS_PUBLIC=false

# Billing (set BILLING_ENABLED=false if you are not using Stripe)
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Release metadata
DESKTOP_RELEASE_SOURCE=file
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_TOKEN=
DESKTOP_RELEASE_CACHE_TTL_SECONDS=60
DESKTOP_RELEASE_TAG=latest
DESKTOP_UPDATE_FEED_DIR=./updates
DESKTOP_UPDATE_ENABLED=true
DESKTOP_VERSION=0.1.0
DESKTOP_WIN_URL=https://example.com/downloads/ai-operator-setup.exe
DESKTOP_MAC_INTEL_URL=https://example.com/downloads/ai-operator-macos-intel.dmg
DESKTOP_MAC_ARM_URL=https://example.com/downloads/ai-operator-macos-apple-silicon.dmg

# Recovery policy
RUN_RECOVERY_POLICY=fail

# Read-only DeFi data aggregator.
# Render may store public API/indexer/RPC keys here. Never store wallet private
# keys, seed phrases, wallet JSON, Cloak viewing keys, or Zerion tokens.
DEFI_FEATURES_ENABLED=true
DEFI_CACHE_TTL_MS=30000
DEFI_REQUEST_TIMEOUT_MS=8000
SOLANA_RPC_MAINNET_URL=
SOLANA_RPC_DEVNET_URL=
HELIUS_API_KEY=
SHYFT_API_KEY=
BIRDEYE_API_KEY=
JUPITER_API_BASE=https://quote-api.jup.ag
KAMINO_API_BASE=
MARGINFI_API_BASE=
ORCA_API_BASE=
RAYDIUM_API_BASE=
METEORA_API_BASE=

# Data retention
AUDIT_RETENTION_DAYS=30
STRIPE_EVENT_RETENTION_DAYS=30
SESSION_RETENTION_DAYS=30
RUN_RETENTION_DAYS=90
ZERION_API_KEY=
