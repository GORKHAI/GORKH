{
  "name": "ai-operator",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "pnpm -w lint:ci",
    "lint:ci": "pnpm --filter @gorkh/web lint && pnpm --filter @gorkh/api typecheck && pnpm --filter @gorkh/shared typecheck && pnpm --filter @gorkh/desktop typecheck",
    "render:api:build": "pnpm --filter @gorkh/shared build && pnpm --filter @gorkh/api prisma:generate && pnpm --filter @gorkh/api build",
    "render:api:start": "pnpm --filter @gorkh/api start",
    "render:api:migrate": "pnpm --filter @gorkh/api prisma:generate && pnpm --filter @gorkh/api migrate:deploy",
    "smoke:from-zero": "bash scripts/smoke/httpSmoke.sh",
    "smoke:ws": "bash scripts/smoke/wsSmoke.sh",
    "smoke:final": "bash scripts/final-smoke.sh",
    "test": "pnpm --filter @gorkh/shared test && pnpm --filter @gorkh/api test && node --import tsx --test --test-force-exit tests/*.test.mjs tests/*.test.ts",
    "typecheck": "turbo run typecheck",
    "version:check": "node scripts/version-check.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check:desktop:csp": "node scripts/check-desktop-csp.mjs",
    "check:desktop:security": "node scripts/check-desktop-security.mjs",
    "check:release:readiness": "node scripts/check-release-readiness.mjs",
    "release:verify:github": "node scripts/release/verify-github-release.mjs",
    "release:verify:api": "node scripts/release/verify-api-feed.mjs",
    "release:verify:packaged": "node scripts/release/verify-packaged-desktop-report.mjs",
    "release:verify": "pnpm release:verify:github && pnpm release:verify:api"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3"
  }
}
